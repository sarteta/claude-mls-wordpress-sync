# MLS provider config
MLS_PROVIDER=mock              # reso | bridge | spark | mock
MLS_BASE_URL=https://api.example-mls.com
MLS_ACCESS_TOKEN=replace-with-your-mls-token
MLS_PAGE_SIZE=200

# WordPress target
WP_BASE_URL=https://your-wp-site.com
WP_USER=integration-bot
WP_APP_PASSWORD=replace-with-wp-app-password
WP_POST_TYPE=listing

# Sync behavior
SYNC_INTERVAL_MINUTES=15
STATE_PATH=./state/listings.json
LOG_LEVEL=INFO
DRY_RUN=false
